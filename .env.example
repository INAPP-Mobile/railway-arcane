# Arcane — Docker Management UI
# Railway Template Environment Variables

# --- Required ---
# Public URL of your deployed Arcane instance
APP_URL=https://your-app.up.railway.app

# Encryption key (generate: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-64-char-hex-string

# --- Optional ---
# User/group ID for file ownership (default: 65532)
# PUID=1000
# PGID=1000
